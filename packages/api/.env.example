# GlassPipe API — environment variables
# Copy this file to .env for local development (never commit .env).
# On Railway, set these via: railway variables set KEY=VALUE

# ── Required ──────────────────────────────────────────────────────────────────

# Postgres connection string. Railway sets this automatically when you run:
#   railway add --database postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Set after first railway domain ────────────────────────────────────────────

# Base URL for share links returned by POST /v1/share.
# Set to your Railway URL immediately after deployment, then update to your
# custom domain (e.g. https://glasspipe.dev) once DNS is configured.
GLASSPIPE_BASE_URL=https://<your-name>.up.railway.app

# ── Optional — all have sensible defaults ────────────────────────────────────

# Port to listen on. Railway sets this automatically — do not override on Railway.
# PORT=5051

# Maximum accepted payload size for POST /v1/share. Requests larger than this
# receive 413 Payload Too Large.
# GLASSPIPE_MAX_PAYLOAD_MB=5

# How many days a shared trace stays live before expiring (410 Gone).
# GLASSPIPE_TRACE_TTL_DAYS=30
