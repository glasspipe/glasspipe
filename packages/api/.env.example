# GlassPipe API — environment variables
# Copy this file to .env for local development (never commit .env).
# In production, set these in Vercel Project Settings > Environment Variables.

# ── Required ──────────────────────────────────────────────────────────────────

# Supabase transaction pooler connection string.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Public URL ────────────────────────────────────────────────────────────────

# Base URL for share links returned by POST /v1/share.
GLASSPIPE_BASE_URL=https://glasspipe.dev

# ── Optional — all have sensible defaults ────────────────────────────────────

# Port to listen on when running the API locally.
# PORT=5051

# Maximum accepted payload size for POST /v1/share. Requests larger than this
# receive 413 Payload Too Large.
# GLASSPIPE_MAX_PAYLOAD_MB=5

# How many days a shared trace stays live before expiring (410 Gone).
# GLASSPIPE_TRACE_TTL_DAYS=30
